{
  "name": "vigile-mcp",
  "mcpName": "io.github.Vigile-ai/vigile-mcp",
  "version": "0.1.10",
  "description": "MCP server for Vigile AI Security — query trust scores for MCP servers and agent skills from within Claude Code, Cursor, and other AI agents",
  "license": "MIT",
  "author": "Vigile AI <support@vigile.dev>",
  "homepage": "https://vigile.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vigile-ai/vigile-mcp.git"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "security",
    "ai-security",
    "trust-score",
    "trust",
    "vigile",
    "ai-agent",
    "vulnerability-scanner",
    "claude",
    "cursor",
    "agent-security"
  ],
  "type": "module",
  "bin": {
    "vigile-mcp": "dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "test": "npm run build && node --test tests/**/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "audit:check": "npm audit --omit=dev --audit-level=moderate",
    "audit:all": "npm audit --audit-level=moderate",
    "preversion": "npm run validate:manifest && npm run build && npm run lint && npm run test && npm run audit:check",
    "prepublishOnly": "npm run build && npm run lint && npm run audit:check",
    "validate:manifest": "node scripts/validate_manifest_sync.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "eslint": "^10.0.3",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.57.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
